{
  "name": "zotero-paper-copilot",
  "type": "module",
  "version": "0.1.0",
  "description": "AI Assistant for Research Papers - Moonlight-like plugin for Zotero",
  "config": {
    "addonName": "Zotero Paper Copilot",
    "addonID": "paper-copilot@github.com",
    "addonRef": "paper-copilot",
    "addonInstance": "PaperCopilot",
    "prefsPrefix": "extensions.zotero.papercopilot"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShiWenber/zotero-paper-copilot.git"
  },
  "author": "ShiWenber",
  "bugs": {
    "url": "https://github.com/ShiWenber/zotero-paper-copilot/issues"
  },
  "homepage": "https://github.com/ShiWenber/zotero-paper-copilot#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.8",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.3",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
